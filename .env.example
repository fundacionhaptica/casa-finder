# Copiar a .env y rellenar.
# .env NUNCA se sube a git (ver .gitignore).

# Llave interna para llamar al vision-router (la misma que usa proyecto-ia).
VISION_INTERNAL_API_KEY=

# Proveedor LLM por defecto: gemini | ollama
LLM_PROVIDER=gemini

# URL del vision-router en la red Docker interna.
VISION_ROUTER_URL=http://vision-router:8003

# Zona horaria.
TZ=Europe/Madrid

# Cron del scraper diario (formato cron).
SCRAPER_CRON=0 4 * * *